{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "umaxica-apps-edge-jump",
  "main": "src/cloudflare.ts",
  "compatibility_date": "2026-05-26",
  "compatibility_flags": ["nodejs_compat"],
  "version_metadata": {
    "binding": "UMAXICA-APPS-EDGE-JUMP-VERSION"
  },
  "ratelimits": [
    {
      "name": "ratelimit",
      "namespace_id": "999",
      "simple": {
        "limit": 10000,
        "period": 10
      }
    }
  ],
  "secrets_store_secrets": [
    {
      "binding": "UMAXICA_JUMP_PRIVATE_KEY_PEM",
      "store_id": "eb74dec1a757471281526676fb6e6509",
      "secret_name": "UMAXICA_JUMP_PRIVATE_KEY_PEM"
    }
  ],
  "workers_dev": false,
  "routes": [
    {
      "pattern": "jump.umaxica.net",
      "zone_name": "umaxica.net",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
