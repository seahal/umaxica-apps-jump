{
  "name": "umaxica-apps-jump",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "pnpm exec oxfmt --write .",
    "formach:check": "pnpm exec oxfmt --check .",
    "cf:check": "wrangler deploy --dry-run --outdir dist/cloudflare",
    "cf:dev": "wrangler dev --local --ip 0.0.0.0 --port 8787",
    "fastly:build": "fastly compute build",
    "fastly:serve": "fastly compute serve --addr 0.0.0.0:7676",
    "fastly:serve:watch": "fastly compute serve --addr 0.0.0.0:7676 --watch",
    "lint": "pnpm exec oxlint --type-aware --type-check --fix .",
    "lint:check": "pnpm exec oxlint --type-aware --type-check .",
    "type": "tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm run type",
    "test": "vp test run",
    "test:cov": "vp test run --coverage",
    "prepare": "vp config"
  },
  "dependencies": {
    "@fastly/hono-fastly-compute": "^0.3.10",
    "@fastly/js-compute": "^3.42.1",
    "hono": "^4.12.22",
    "jose": "^6.2.3",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@cloudflare/vite-plugin": "^1.38.0",
    "@cloudflare/workers-types": "catalog:",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260519.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "happy-dom": "^20.9.0",
    "knip": "^6.14.2",
    "miniflare": "^4.20260521.0",
    "vite-plugin-babel": "^1.7.3",
    "vite-plus": "catalog:",
    "vite-ssr-components": "^0.6.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:",
    "wrangler": "^4.94.0"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "fast-xml-parser": "5.3.8",
      "ajv": ">=8.18.0"
    },
    "ignoredBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
