{
  "name": "umaxica-apps-jump",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "vp fmt . --write",
    "format:check": "vp fmt . --check",
    "cloudflare:check": "vp exec wrangler deploy --dry-run --outdir dist/cloudflare",
    "cloudflare:dev": "vp exec wrangler dev --local --ip 0.0.0.0 --port 8787",
    "fastly:build": "fastly compute build",
    "fastly:serve": "fastly compute serve --addr 0.0.0.0:7676",
    "fastly:serve:watch": "fastly compute serve --addr 0.0.0.0:7676 --watch",
    "lint": "vp lint --type-aware --fix .",
    "lint:check": "vp lint --type-aware .",
    "type": "vp check --no-fmt --no-lint",
    "typecheck": "vp run type",
    "test": "vp test run",
    "test:cov": "vp test run --coverage",
    "test:e2e": "vp exec playwright test",
    "test:all": "vp run test && vp run test:e2e",
    "prepare": "vp config"
  },
  "dependencies": {
    "@fastly/hono-fastly-compute": "^0.3.10",
    "@fastly/js-compute": "^3.42.1",
    "hono": "^4.12.23",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@hono/node-server": "^2.0.4",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "knip": "^6.14.2",
    "tsx": "^4.22.3",
    "vite-plus": "catalog:",
    "wrangler": "^4.95.0"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "fast-xml-parser": "5.3.8",
      "ajv": ">=8.18.0"
    },
    "ignoredBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
